# Скопируйте в .env. По умолчанию — локальный файл SQLite в каталоге backend
DATABASE_URL=sqlite+aiosqlite:///./near.db

# PostgreSQL (docker compose up -d postgres):
# DATABASE_URL=postgresql+asyncpg://near:near@localhost:5432/near
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# Секрет подписи JWT (в проде — длинная случайная строка)
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
TASK_ARCHIVE_RETENTION_DAYS=30

# development | production (в production обязательны сильный JWT_SECRET и CORS_ORIGINS)
ENV=development

# Домены фронтенда через запятую (обязательно в production)
# CORS_ORIGINS=https://app.example.com

# Доверенные Host-заголовки (опционально, production за reverse-proxy)
# TRUSTED_HOSTS=app.example.com,api.example.com

# Юридические реквизиты оператора (шаблон — заменить перед продом)
LEGAL_OPERATOR_NAME=Near (разработка)
LEGAL_CONTACT_EMAIL=privacy@example.com

# Уведомления по email (опционально; без SMTP — только in-app)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# NOTIFICATION_EMAIL_FROM=near@example.com
# DUE_REMINDER_HOURS=24
