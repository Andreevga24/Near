# Скопируйте в .env.prod и замените значения перед деплоем.
# Запуск: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# --- PostgreSQL (только внутри Docker-сети) ---
POSTGRES_USER=near
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=near

# --- Backend (production) ---
# Сгенерировать: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# Публичный URL фронтенда (с https://). Через nginx /api — тот же домен.
CORS_ORIGINS=https://near.example.com

# Host-заголовок, который приходит от reverse proxy
TRUSTED_HOSTS=near.example.com

RATE_LIMIT_ENABLED=true
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
TASK_ARCHIVE_RETENTION_DAYS=30

# Юридические реквизиты (152-ФЗ)
LEGAL_OPERATOR_NAME=ООО «Пример»
LEGAL_CONTACT_EMAIL=privacy@example.com

# SMTP (опционально)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# NOTIFICATION_EMAIL_FROM=near@example.com
# DUE_REMINDER_HOURS=24

# Порт HTTP на хосте (TLS — на внешнем прокси)
HTTP_PORT=80
